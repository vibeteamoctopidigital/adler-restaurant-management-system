{
  "name": " Blitz-analyzer backend",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate && npm run build:vercel",
    "predev": "prisma generate",
    "dev": "npx tsx watch src/server.ts",
    "build:vercel": "esbuild src/vercel.ts --bundle --platform=node --format=esm --packages=external --target=node20 --outfile=api/index.js && node scripts/copy-prisma-engine.mjs",
    "build": "prisma generate && prisma migrate deploy && tsup",
    "migrate": "prisma generate && prisma db push",
    "prisma:generate": "prisma generate",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "stripe:webhook": "stripe listen --forward-to localhost:5000/api/v1/stripe/webhook",
    "seed": "prisma db seed"
  },
  "author": "",
  "license": "ISC",
