// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}



// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  ADMIN
  EMPLOYEE
}

enum ContractType {
  HOURLY
  MONTHLY_SALARY
  WORKLOAD_PERCENT
}

enum PlanStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
}

enum ShiftStatus {
  PENDING       // assigned, awaiting employee accept/reject
  ACCEPTED
  REJECTED
  CANCELLED
  SWAPPED_OUT   // moved away from this employee via an approved swap
}

enum AvailabilityMonthStatus {
  DRAFT
  SUBMITTED
  LOCKED        // past cutoff — admin is now building the schedule from it
}

enum DayAvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  WISH
}

enum SwapStatus {
  PENDING_RECIPIENT        // waiting for the other employee to agree
  PENDING_ADMIN_APPROVAL   // both employees agreed, waiting on admin
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum NotificationType {
  WEEKLY_SHIFTS_PUBLISHED
  AVAILABILITY_REMINDER
  SWAP_REQUEST_RECEIVED
  SWAP_REQUEST_RESULT
  SHIFT_CHANGED
  RULE_VIOLATION
  GENERAL
}

enum NotificationChannel {
  PUSH
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum CredentialDeliveryMethod {
  EMAIL
  SMS
  IN_PERSON
}

// =============================================================================
// AUTH / CORE USER
// -----------------------------------------------------------------------------
// Spec 3.2 / 4.1 — one login table for Admin and Employee.
// mustChangePassword enforces the forced-change-on-first-login rule for
// every admin-created account (spec 1, "Employee accounts").
// =============================================================================

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  role               Role
  mustChangePassword Boolean   @default(true)
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  employeeProfile      EmployeeProfile?

  // admin-side relations
  submittedPlans       WeeklyPlan[]          @relation("PlanSubmittedBy")
  approvedSwaps        SwapRequest[]         @relation("SwapAdmin")
  auditLogs            AuditLog[]            @relation("AuditActor")
  credentialDeliveries CredentialDelivery[]  @relation("DeliveredBy")
  ruleCheckLogs        RuleCheckLog[]        @relation("RuleCheckActor")

  notifications        Notification[]
  refreshTokens        RefreshToken[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

// Refresh tokens for the React (web) + React Native (mobile) clients.
// Kept separate from User so multiple devices (phone + tablet) can hold
// independent, individually-revocable sessions.
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  deviceInfo String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Spec 5.6 — "default passwords must be delivered securely... changing
// them must be forced, not optional." This is the audit trail answering
// the open question of HOW a password reached the employee.
model CredentialDelivery {
  id            String                    @id @default(cuid())
  employeeId    String
  employee      EmployeeProfile           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  method        CredentialDeliveryMethod
  deliveredById String?
  deliveredBy   User?                     @relation("DeliveredBy", fields: [deliveredById], references: [id])
  deliveredAt   DateTime                  @default(now())
  note          String?

  @@index([employeeId])
  @@map("credential_deliveries")
}

// =============================================================================
// EMPLOYEE PROFILE & CONTRACT
// -----------------------------------------------------------------------------
// Spec 3.5 — Employees: add/edit, contract details, qualifications,
// deactivate (soft-delete keeps history, per spec).
// =============================================================================

model EmployeeProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  phone     String?

  contractType           ContractType
  workloadPercent        Decimal? @db.Decimal(5, 2) // e.g. 80.00 = 80%
  hourlyRate             Decimal? @db.Decimal(10, 2)
  monthlySalary          Decimal? @db.Decimal(10, 2)
  contractedHoursMonthly Decimal? @db.Decimal(6, 2) // target used for "hours due" (spec 3.7)

  hireDate      DateTime?
  deactivatedAt DateTime? // soft delete — keeps history, drops from active scheduling

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories           EmployeeCategory[]
  availabilityMonths   AvailabilityMonth[]
  shifts               Shift[]
  initiatedSwaps       SwapRequest[]        @relation("SwapInitiator")
  receivedSwaps        SwapRequest[]        @relation("SwapRecipient")
  credentialDeliveries CredentialDelivery[]

  @@index([deactivatedAt])
  @@index([lastName, firstName])
  @@map("employee_profiles")
}

// =============================================================================
// CATEGORIES OF WORK
// -----------------------------------------------------------------------------
// Spec 3.6 — top-level categories (service, kitchen, bar, office,
// commande, dishwashing) with an OPTIONAL sub-category, modeled as a
// self-relation so a category can be used directly with no sub-category.
// =============================================================================

model Category {
  id       String     @id @default(cuid())
  name     String
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees EmployeeCategory[]
  shifts    Shift[]

  @@unique([parentId, name])
  @@index([parentId])
  @@map("categories")
}

// Qualification assignment — drives the "category dropdown only shows
// categories the employee is qualified for" rule in Manage Plans (3.4).
model EmployeeCategory {
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assignedAt DateTime        @default(now())

  @@id([employeeId, categoryId])
  @@index([categoryId])
  @@map("employee_categories")
}

// =============================================================================
// AVAILABILITY
// -----------------------------------------------------------------------------
// Spec 4.3 — monthly availability, per day: Available / Unavailable /
// Wish, optional note, binding submit before a cutoff.
// =============================================================================

model AvailabilityMonth {
  id         String                  @id @default(cuid())
  employeeId String
  employee   EmployeeProfile         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  year        Int
  month       Int // 1-12
  status      AvailabilityMonthStatus @default(DRAFT)
  cutoffAt    DateTime
  submittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  days AvailabilityDay[]

  @@unique([employeeId, year, month])
  @@index([year, month])
  @@index([status])
  @@map("availability_months")
}

model AvailabilityDay {
  id                  String            @id @default(cuid())
  availabilityMonthId String
  availabilityMonth   AvailabilityMonth @relation(fields: [availabilityMonthId], references: [id], onDelete: Cascade)

  date               DateTime               @db.Date
  status             DayAvailabilityStatus
  note               String?
  preferredStartTime DateTime? // time-of-day the employee submitted
  preferredEndTime   DateTime?

  @@unique([availabilityMonthId, date])
  @@index([date])
  @@map("availability_days")
}

// =============================================================================
// WEEKLY PLAN (built inside a monthly cycle) + SHIFTS
// -----------------------------------------------------------------------------
// Spec 3.4 / 5.1 — admin builds & submits week by week inside a month;
// "full month view" merges all submitted weeks for that month.
// =============================================================================

model WeeklyPlan {
  id            String   @id @default(cuid())
  year          Int
  month         Int // 1-12 — the month this week is grouped under
  weekNumber    Int // 1-5 — position of the week inside that month
  weekStartDate DateTime @db.Date
  weekEndDate   DateTime @db.Date

  status        PlanStatus @default(DRAFT)
  submittedAt   DateTime?
  submittedById String?
  submittedBy   User?      @relation("PlanSubmittedBy", fields: [submittedById], references: [id])

  // Set when an already-submitted week is edited, so the notification
  // layer knows a re-notify is owed to affected employees (spec 5.1).
  needsRenotify Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts Shift[]

  @@unique([year, month, weekNumber])
  @@index([status])
  @@index([weekStartDate, weekEndDate])
  @@map("weekly_plans")
}

model Shift {
  id           String     @id @default(cuid())
  weeklyPlanId String
  weeklyPlan   WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)

  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  date DateTime @db.Date

  // Stored as full UTC timestamps (not just a "time" column) so that
  // shifts crossing a DST change night are unambiguous — spec 5.6.
  startTime DateTime
  endTime   DateTime

  status          ShiftStatus @default(PENDING)
  rejectionReason String?

  // Snapshot of the rule check, always visible to admin, never hidden
  // (spec 3.4 — "violations shown in plain language, never hidden").
  ruleViolations Json?
  rulePassed     Boolean @default(true)

  notifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  swapsAsInitiatorShift SwapRequest[] @relation("InitiatorShift")
  swapsAsRecipientShift SwapRequest[] @relation("RecipientShift")

  @@index([employeeId, date])
  @@index([weeklyPlanId])
  @@index([categoryId])
  @@index([date, status])
  @@map("shifts")
}

// =============================================================================
// SHIFT APPROVALS (SWAPS)
// -----------------------------------------------------------------------------
// Spec 3.9 / 4.5 / 5.2 — two employees exchange shifts, admin gives the
// final approval. This model does NOT handle normal accept/reject of an
// assigned shift — that's a direct action on Shift.status.
// =============================================================================

model SwapRequest {
  id String @id @default(cuid())

  initiatorEmployeeId String
  initiatorEmployee    EmployeeProfile @relation("SwapInitiator", fields: [initiatorEmployeeId], references: [id], onDelete: Cascade)
  initiatorShiftId    String
  initiatorShift       Shift           @relation("InitiatorShift", fields: [initiatorShiftId], references: [id], onDelete: Cascade)

  recipientEmployeeId String
  recipientEmployee    EmployeeProfile @relation("SwapRecipient", fields: [recipientEmployeeId], references: [id], onDelete: Cascade)
  recipientShiftId    String?
  recipientShift       Shift?          @relation("RecipientShift", fields: [recipientShiftId], references: [id], onDelete: Cascade)

  status               SwapStatus @default(PENDING_RECIPIENT)
  recipientRespondedAt DateTime?

  // Rule check is re-run the instant Admin clicks Approve, not only at
  // request time (spec 5.2) — this always holds the LATEST result.
  ruleCheckResult  Json?
  ruleCheckPassed  Boolean?
  ruleCheckedAt    DateTime?

  adminId      String?
  admin        User?     @relation("SwapAdmin", fields: [adminId], references: [id])
  adminReason  String?
  resolvedAt   DateTime?
  expiresAt    DateTime? // answers open question: auto-expire policy, if adopted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([initiatorEmployeeId])
  @@index([recipientEmployeeId])
  @@index([status])
  @@index([initiatorShiftId])
  @@index([recipientShiftId])
  @@map("swap_requests")
}

// -----------------------------------------------------------------------------
// IMPORTANT — enforcing "only one swap can be approved per shift" (spec 5.2):
// Prisma cannot declare a conditional/partial unique constraint ("unique
// only where status = APPROVED") across all providers. On Postgres, add
// this via a raw migration after `prisma migrate dev`:
//
//   CREATE UNIQUE INDEX swap_initiator_shift_approved_uidx
//     ON "swap_requests" ("initiatorShiftId") WHERE status = 'APPROVED';
//   CREATE UNIQUE INDEX swap_recipient_shift_approved_uidx
//     ON "swap_requests" ("recipientShiftId") WHERE status = 'APPROVED';
//
// The application must ALSO wrap the approval in a serializable
// transaction (SELECT ... FOR UPDATE on both shifts) so a second
// conflicting swap is rejected with a clear message rather than a raw
// DB error.
// -----------------------------------------------------------------------------

// =============================================================================
// RULE ENGINE (L-GAV) — SETTINGS + AUDIT
// -----------------------------------------------------------------------------
// Spec 3.8 / 5.4 — values live in settings, not hardcoded, so a wrong
// number can be fixed fast. Every automated check is logged for audit.
// =============================================================================

// Singleton row (id is always 1) — one restaurant, one rule set.
model OrgSettings {
  id Int @id @default(1)

  maxDailyHours             Decimal @db.Decimal(4, 2)
  maxWeeklyHours            Decimal @db.Decimal(4, 2)
  minRestHoursBetweenShifts Decimal @db.Decimal(4, 2)
  minBreakMinutes           Int
  breakRules                Json? // e.g. break length thresholds by shift length

  sessionTimeoutMinutes Int   @default(30)
  notificationPrefs     Json? // default channel per NotificationType

  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("org_settings")
}

model RuleCheckLog {
  id          String   @id @default(cuid())
  context     String // "SHIFT_CREATE" | "SHIFT_EDIT" | "SWAP_APPROVE" ...
  entityId    String // shiftId or swapRequestId
  passed      Boolean
  details     Json
  checkedAt   DateTime @default(now())
  checkedById String?
  checkedBy   User?    @relation("RuleCheckActor", fields: [checkedById], references: [id])

  @@index([context, entityId])
  @@index([checkedAt])
  @@map("rule_check_logs")
}

// =============================================================================
// NOTIFICATIONS
// -----------------------------------------------------------------------------
// Spec 5.3 — per-week alerts, not once a month; email as backup for PWA
// push unreliability. channel + status lets one logical event fan out
// into several delivery attempts (push AND email for the same event).
// =============================================================================

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  channel NotificationChannel
  status  NotificationStatus  @default(PENDING)

  title   String
  body    String
  payload Json? // e.g. { weeklyPlanId } or { swapRequestId }

  sentAt     DateTime?
  readAt     DateTime?
  failReason String?

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([userId, readAt])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// AUDIT LOG — general admin actions (deactivation, edit-after-submit, etc.)
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  action     String // e.g. "EMPLOYEE_DEACTIVATED", "WEEK_EDITED_AFTER_SUBMIT"
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

