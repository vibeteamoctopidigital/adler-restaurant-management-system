# Server Configuration
PORT=8000
NODE_ENV=development

# Database Connection
DATABASE_URL=postgresql://username:password@localhost:5432/database_name?schema=public

# Client URL (CORS / Frontend)
CLIENT_URL=http://localhost:3000

# Security and JWT
JWT_SECRET=super_secret_jwt_signing_key_at_least_32_chars_long
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=12

ACCESS_TOKEN_SECRET=super_secret_access_token_signing_key_at_least_32_chars_long
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=super_secret_refresh_token_signing_key_at_least_32_chars_long
REFRESH_TOKEN_EXPIRES_IN=7d

# Rate limiting (optional — sensible defaults applied if omitted)
RATE_LIMIT_WINDOW_MS=900000   # window per IP, in ms (default 15 min)
RATE_LIMIT_MAX=1000           # max requests / window / IP for the whole API
AUTH_RATE_LIMIT_MAX=20        # max FAILED login/refresh attempts / window / IP

# Reverse proxies in front of the app (for correct client IPs). Default 1.
TRUST_PROXY_HOPS=1

# Shift reminders (5h / 3h / 1h before a confirmed shift starts)
# Secret guarding the cron dispatch endpoint (GET/POST /api/v1/cron/reminders).
# Vercel Cron auto-sends this as `Authorization: Bearer <CRON_SECRET>`. >=16 chars.
CRON_SECRET=change_me_to_a_long_random_cron_secret
# In-process scheduler cadence for the long-lived server (minutes). Default 15.
REMINDER_INTERVAL_MIN=15
# Run the dispatcher in-process on a long-lived server (dev/self-hosted).
# Leave 'true' when self-hosting; set 'false' on serverless (Vercel uses cron).
REMINDER_INPROCESS_CRON=true

# Logging (optional): pino level — trace|debug|info|warn|error|fatal
LOG_LEVEL=info
