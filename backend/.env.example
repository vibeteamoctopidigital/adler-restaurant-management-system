# Server Configuration
PORT=8000
NODE_ENV=development

# Database Connection
DATABASE_URL=postgresql://username:password@localhost:5432/database_name?schema=public

# Client URL (CORS / Frontend)
CLIENT_URL=http://localhost:3000

# Security and JWT
JWT_SECRET=super_secret_jwt_signing_key_at_least_32_chars_long
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=12

ACCESS_TOKEN_SECRET=super_secret_access_token_signing_key_at_least_32_chars_long
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=super_secret_refresh_token_signing_key_at_least_32_chars_long
REFRESH_TOKEN_EXPIRES_IN=7d

# Rate limiting (optional — sensible defaults applied if omitted)
RATE_LIMIT_WINDOW_MS=900000   # window per IP, in ms (default 15 min)
RATE_LIMIT_MAX=1000           # max requests / window / IP for the whole API
AUTH_RATE_LIMIT_MAX=20        # max FAILED login/refresh attempts / window / IP

# Reverse proxies in front of the app (for correct client IPs). Default 1.
TRUST_PROXY_HOPS=1

# Logging (optional): pino level — trace|debug|info|warn|error|fatal
LOG_LEVEL=info
